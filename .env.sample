# ============================================================================
# Deploy (Hardhat) — usado por scripts/prepare.ts, deploy.ts, verify.ts
# Carregado automaticamente por dotenv em hardhat.config.ts
# ============================================================================

# Nome da network em NETWORK_CONFIG de hardhat.config.ts (mainnet, basemain, ...)
# NETWORK=mainnet

# RPC da Alchemy (use uma app SEM restrição de domínio para CI/deploy)
ALCHEMY_KEY=

# Private key do deployer (alternativa: arquivo keystore.json)
# PRIVATE_KEY=

# Endereços são persistidos automaticamente em deployments/<chainId>.json pelo deploy.ts.
# Só defina as variáveis abaixo se quiser sobrescrever o arquivo persistido:
# FACTORY=
# ROUTER=
# WRAPPER=
# PAIR=
# FACTORY_FROM=

# ============================================================================
# Subgraph — usado por subgraph/package.json (mustache template)
# As linhas {{...}} são substituídas por subgraph/config/<chain>.json
# ============================================================================

# Goldsky — deploy não-interativo via CLI. Obtenha em app.goldsky.com → API Keys.
# Usado por `pnpm goldsky:login` (faz login uma vez, persiste em ~/.goldsky/config).
GOLDSKY_API_KEY=

ACCESS_TOKEN=
DEPLOY_KEY=
NETWORK={{NETWORK}}
SLUG_HOSTED=
SLUG_STUDIO=
USER_HOSTED=
ENV_HOSTED=
SQUID_DEPLOYMENT_KEY=
